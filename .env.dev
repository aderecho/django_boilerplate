DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-dev
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

DB_NAME=boilerplate_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

REDIS_URL=redis://redis:6379/0

JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

PAGINATION_PAGE_SIZE=10
API_TITLE=Laravel-Style Django API Boilerplate
API_VERSION=1.0.0
API_DESCRIPTION=Production-ready Django REST API boilerplate.

CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
