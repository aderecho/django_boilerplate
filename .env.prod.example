DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.example.com,localhost

DB_NAME=boilerplate_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

CORS_ALLOWED_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://app.example.com,https://api.example.com

REDIS_URL=redis://redis:6379/0

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

PAGINATION_PAGE_SIZE=20
API_TITLE=Laravel-Style Django API Boilerplate
API_VERSION=1.0.0
API_DESCRIPTION=Production-ready Django REST API boilerplate.

CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
